+bool llama_context::set_meta_adapter(const char * sidecar_path) {
+    auto meta = std::make_shared<llama_adapter_meta>();
+    if (!meta->load(sidecar_path)) {
+        LLAMA_LOG_ERROR("%s: failed to load meta sidecar %s\n", __func__, sidecar_path);
+        return false;
+    }
+    cvec = meta;  // polymorphic substitution: the graph calls cvec->apply_to → CA injection
+    sched_need_reserve = true;
+    return true;
+}
+
+bool llama_context::set_meta_cog(const float * data, int32_t n_cog, int32_t n_embd) {
+    auto * meta = dynamic_cast<llama_adapter_meta *>(cvec.get());
+    if (!meta) { LLAMA_LOG_ERROR("%s: meta adapter not set\n", __func__); return false; }
+    meta->set_cog(data, n_cog, n_embd);
+    return true;
+}
+
+bool llama_context::meta_encode(const float * acts, int32_t n_layers, int32_t n_embd) {
+    auto * meta = dynamic_cast<llama_adapter_meta *>(cvec.get());
+    if (!meta) { LLAMA_LOG_ERROR("%s: meta adapter not set\n", __func__); return false; }
+    return meta->encode(acts, n_layers, n_embd);
+}
