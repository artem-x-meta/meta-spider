+//
+// llama_adapter_meta — meta-spider Doubter: cross-attention injection of cognitive tokens
+// into the residual stream of selected layers (mechanics like a control-vector hook, but
+// instead of a static vector — an input-dependent BottleneckCrossAttention). Weights from a
+// GGUF sidecar. Substitutes cvec in the context (polymorphically via apply_to). Target CPU.
+//
+
+struct llama_adapter_meta : llama_adapter_cvec {
+    // Load CA weights from a GGUF sidecar (ca.<layer>.*) + parse the metadata.
+    bool load(const char * sidecar_path);
+
+    // Set cognitive tokens (after Pass-1): data = [n_cog * n_embd] row-major (per token).
+    void set_cog(const float * data, int n_cog_in, int n_embd_in);
+
+    // Run the built-in encoder: acts [n_layers * n_embd] (per layer) → cognitive tokens
+    // (writes directly into the cog tensor, enables injection). No subprocess — for dynamic refresh.
+    bool encode(const float * acts, int n_layers, int n_embd_in);
+
+    // CA injection for cross_attn layers; otherwise the residual is unchanged.
+    ggml_tensor * apply_to(ggml_context * ctx, ggml_tensor * cur, int il) const override;
+
+private:
+    int n_embd_m = 0, bottleneck = 0, n_cog = 0, n_head = 0, head_dim = 0;
+    std::vector<int> cross_layers;                 // {6,12,18,24}
+
+    ggml_context_ptr wctx;                          // CA weights (from sidecar, in backend buffer)
+    ggml_backend_buffer_ptr wbuf;
+    ggml_context_ptr cctx;                          // cog tensor
+    ggml_backend_buffer_ptr cbuf;
+
+    ggml_tensor * cog = nullptr;                    // [n_embd, n_cog]
+    bool cog_ready = false;                          // Pass-1 clean (no inject) until cog is set
+    // per cross_attn layer: name→tensor (norm/down/q/k/v/up/token_preference) + tanh(gate)
+    std::unordered_map<int, std::unordered_map<std::string, ggml_tensor *>> ca;
+    std::unordered_map<int, float> gate_tanh;
+
+    // built-in encoder (enc.<key> → tensor) for encode()/dynamic refresh
+    std::unordered_map<std::string, ggml_tensor *> enc;
+    int enc_n_head = 8;
+    std::string enc_type = "multi_token";  // 'selective' (current) | 'multi_token' (legacy)
+    ggml_backend_ptr enc_backend;  // CPU backend for the encode graph
+
+    bool is_cross(int il) const;
+};
