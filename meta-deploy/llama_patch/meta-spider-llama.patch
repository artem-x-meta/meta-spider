 llm_graph_result * llama_context::process_ubatch(const llama_ubatch & ubatch, llm_graph_type gtype, llama_memory_context_i * mctx, ggml_status & ret) {
     if (mctx && !mctx->apply()) {
         LLAMA_LOG_ERROR("%s: failed to apply memory context\n", __func__);
@@ -3812,6 +3836,18 @@ int32_t llama_set_adapter_cvec(
     return res ? 0 : -1;
 }
 
+int32_t llama_set_meta_adapter(llama_context * ctx, const char * sidecar_path) {
+    return ctx->set_meta_adapter(sidecar_path) ? 0 : -1;
+}
+
+int32_t llama_set_meta_cog(llama_context * ctx, const float * data, int32_t n_cog, int32_t n_embd) {
+    return ctx->set_meta_cog(data, n_cog, n_embd) ? 0 : -1;
+}
+
+int32_t llama_meta_encode(llama_context * ctx, const float * acts, int32_t n_layers, int32_t n_embd) {
+    return ctx->meta_encode(acts, n_layers, n_embd) ? 0 : -1;
+}
